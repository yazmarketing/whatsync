{
  "manifest_version": 3,
  "name": "WhatsApp Web Extension",
  "version": "1.0.0",
  "description": "Extension that only works on web.whatsapp.com",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://whatsync.io/*",
    "https://www.whatsync.io/*",
    "https://cxzeixolbajmgyzedylt.supabase.co/*",
    "https://dizxmubrpwwfrjepcttb.supabase.co/*",
    "https://*.supabase.co/*",
    "https://api.hubapi.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://whatsync.io/*", "https://www.whatsync.io/*"],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["supabase.js"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}
